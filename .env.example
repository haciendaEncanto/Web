# ============================================================
# Hacienda El Encanto — Variables de entorno
# Copiar a .env.local y completar con valores reales.
# NUNCA commitear .env.local
# ============================================================

# Supabase — obtener desde: Settings > API en el dashboard de Supabase
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Service Role — solo para scripts del servidor / migrations, NUNCA exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key
